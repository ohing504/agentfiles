{
  "name": "agentfiles",
  "type": "module",
  "version": "0.1.0",
  "description": "AI agent configuration file manager and community platform",
  "license": "MIT",
  "keywords": [
    "claude",
    "agent",
    "config",
    "mcp",
    "plugin",
    "agentfiles"
  ],
  "bin": {
    "agentfiles": "./dist/cli.js"
  },
  "files": [
    "dist/",
    ".output/"
  ],
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:app": "vite dev --port 3000 & sleep 2 && open -a 'Google Chrome' --args --app=http://localhost:3000 && wait",
    "build": "vite build && node scripts/build-cli.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "preview": "vite preview",
    "start": "node dist/cli.js",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.12.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-store": "^0.9.1",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "nitro": "latest",
    "open": "^11.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.27.3",
    "jsdom": "^27.0.0",
    "lefthook": "^2.1.1",
    "shadcn": "^3.8.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
  }
}
